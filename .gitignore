# --- Node / npm -----------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- TypeScript build output ---------------------------------------------
# Regenerated by `npm run compile`.
out/
*.tsbuildinfo

# --- Vendored Three.js ---------------------------------------------------
# scripts/copy-three.js (postinstall) repopulates this from node_modules/three.
media/three/

# --- Packaged extension --------------------------------------------------
# Distribute via GitHub Releases, not in the repo.
*.vsix

# --- VSCode workspace state ----------------------------------------------
# Keep launch.json / tasks.json (committed for collaborators); ignore the rest.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
.vscode-test/
.history/

# --- IDE / editor --------------------------------------------------------
.idea/
*.swp
*.swo
*~

# --- OS junk -------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Secrets / local config (defensive) ---------------------------------
.env
.env.*
*.key
*.pem
secrets.json

# --- Misc local scratch --------------------------------------------------
*.log
tmp/
.tmp/
